<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.appcineindie.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.appcineindie.login.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register" >
        <action
            android:id="@+id/action_registerFragment_to_userTypeFragment"
            app:destination="@id/userTypeFragment" />
    </fragment>

    <fragment
        android:id="@+id/userTypeFragment"
        android:name="com.example.appcineindie.login.UserTypeFragment"
        android:label="User Type"
        tools:layout="@layout/activity_usertype" >
        <action
            android:id="@+id/action_userTypeFragment_to_reviewsFragment"
            app:destination="@id/reviewsFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewsFragment"
        android:name="com.example.appcineindie.ui.ReviewsFragment"
        android:label="Reviews"
        tools:layout="@layout/fragment_reviews" />
</navigation>
